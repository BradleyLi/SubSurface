# Ollama (FastAPI / agent.harness)
WORKFLOW1_OPENAI_BASE_URL=http://127.0.0.1:11436/v1
WORKFLOW1_MODEL=nemotron-nano:12b-v2
# Nemotron-Nano 12B v2 (incl. Vision-Language): 128K token context window
WORKFLOW1_CONTEXT_WINDOW=128000
WORKFLOW1_MAX_TOKENS=256
WORKFLOW1_TEMPERATURE=0
WORKFLOW2_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
WORKFLOW2_MODEL=nemotron-3-super:latest
WORKFLOW2_MAX_TOKENS=1000000
WORKFLOW2_TEMPERATURE=0.3
OPENAI_API_KEY=ollama

# NemoClaw (one-time onboard on GX10)
NEMOCLAW_W1_SANDBOX=hackathon-w1
NEMOCLAW_W2_SANDBOX=nemotron-3-super

# App ports (Streamlit calls FastAPI only)
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
STREAMLIT_PORT=8501
