# Ollama (FastAPI / agent.harness)
WORKFLOW1_OPENAI_BASE_URL=http://127.0.0.1:11436/v1
WORKFLOW1_MODEL=nemotron-nano:12b-v2
# Nemotron-Nano 12B v2 (incl. Vision-Language): 128K token context window
WORKFLOW1_CONTEXT_WINDOW=128000
WORKFLOW1_MAX_TOKENS=5000
WORKFLOW2_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
WORKFLOW2_MODEL=nemotron-3-super:latest
WORKFLOW2_MAX_TOKENS=500000
LLM_TEMPERATURE=0.4
OPENAI_API_KEY=ollama

# NemoClaw (one-time onboard on GX10)
NEMOCLAW_W1_SANDBOX=hackathon-w1
NEMOCLAW_W2_SANDBOX=nemotron-3-super

# App ports (Streamlit calls FastAPI only)
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501

# Standalone push-to-talk voice chat (python agent/harness/voice_bot.py — separate from Streamlit)
VOICE_CHAT_HOST=0.0.0.0
VOICE_CHAT_PORT=8503
# Optional: override browser EventSource URL used by Streamlit pages.
# Defaults to the same hostname that served Streamlit, on VOICE_CHAT_PORT.
VOICE_TRANSCRIPT_EVENTS_URL=
VOICE_OUTPUT_DIR=voice_sessions
VOICE_MODEL_CACHE_DIR=voice_models
# Kokoro downloads Hugging Face weights under voice_models/huggingface/ (not ~/.cache)
VOICE_LLM_PROFILE=workflow1
VOICE_MAX_TOKENS=3000
VOICE_MAX_USER_TURNS=3
VOICE_WHISPER_MODEL=base.en
VOICE_WHISPER_DEVICE=cuda
VOICE_WHISPER_COMPUTE_TYPE=float16

# Local server-side voice playback. Use "kokoro" for a natural local voice,
# "piper" if you have a Piper model, or "none" to keep responses text-only.
# The server generates WAV files and Firefox plays them in the browser.
VOICE_TTS_ENGINE=none
VOICE_TTS_VOICE=af_heart
VOICE_TTS_LANG_CODE=a
# Keep TTS on CPU so Kokoro doesn't compete with Ollama + Whisper for VRAM
VOICE_TTS_DEVICE=cpu
VOICE_PIPER_MODEL=
# Played on the client while waiting for the model (requires VOICE_TTS_ENGINE)
VOICE_HOLD_MESSAGE=I'm looking into this, let me get back to you in a moment.
VOICE_HOLD_MESSAGE_LATER=Ok, let me note that down, please wait.
VOICE_HOLD_MESSAGE_TURN3=Ok, we're almost done here, please bear with me.
