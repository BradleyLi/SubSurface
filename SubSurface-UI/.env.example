# Get a free token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# CityNerve FastAPI backend (dev server proxies /api to this URL)
VITE_API_BASE_URL=

# Vite dev proxy target — match run_citynerve.sh FastAPI port (default http://127.0.0.1:8000)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Voice Reporting Line (default port 8504 from run_citynerve.sh)
VITE_VOICE_CHAT_PORT=8504
# Optional: override SSE / client URLs (leave blank to use defaults)
# VITE_VOICE_EVENTS_URL=
# VITE_VOICE_CLIENT_URL=
# VITE_VOICE_PROXY_TARGET=http://127.0.0.1:8504
