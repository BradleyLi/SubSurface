# Workflow 1 — Nemotron Nano 12B on Ollama :11436 (structured JSON summaries)
WORKFLOW1_OPENAI_BASE_URL=http://127.0.0.1:11436/v1
WORKFLOW1_MODEL=nemotron-nano:12b-v2
WORKFLOW1_MAX_TOKENS=5000

# Workflow 2 — Nemotron Super on Ollama :11434 (multi-role analysis)
WORKFLOW2_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
WORKFLOW2_MODEL=nemotron-3-super:latest
WORKFLOW2_MAX_TOKENS=500000
LLM_TEMPERATURE=0.4
W2_PARALLEL=true

OPENAI_API_KEY=ollama

# Legacy aliases (optional; WORKFLOW1_* takes precedence when both are set)
# OPENAI_API_BASE=http://127.0.0.1:11436/v1
# OPENAI_MODEL=nemotron-nano:12b-v2

# UI → FastAPI (React dev proxy uses VITE_API_PROXY_TARGET; backend default :8000)
# CITYNERVE_API_URL=http://127.0.0.1:8000

# ML predictions snapshot year (default: 2016)
# ML_PREDICTION_YEAR=2016

